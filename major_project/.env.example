# ========================================
# ELECTIVE MANAGEMENT SYSTEM - CONFIGURATION
# ========================================
# 
# QUICK SETUP (Minimum Required):
# 1. Copy this file and rename to ".env"
# 2. Update MONGODB_URI with your database URL
# 3. Change JWT_SECRET to a random secure string
# 4. Run: npm install
# 5. Run: npm start
# 
# That's it! The system will work without email configuration.
# Email is OPTIONAL - if not configured, password reset tokens will be logged to console.
# ========================================

# ===== REQUIRED CONFIGURATION =====

# MongoDB Database URL (GET THIS FROM: https://cloud.mongodb.com)
# 1. Create free cluster at MongoDB Atlas
# 2. Create database user
# 3. Get connection string and replace below
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/elective-system?retryWrites=true&w=majority

# JWT Secret - Change this to ANY random string (for security)
# Example: my-super-secret-college-project-2025
JWT_SECRET=your-secret-key-here

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (Change in production to your deployed frontend URL)
FRONTEND_URL=http://localhost:5173

# ===== OPTIONAL: EMAIL CONFIGURATION =====
# Leave these empty/commented if you don't want to setup email
# Password reset tokens will be logged to server console instead
# 
# To enable email (Gmail example):
# 1. Enable 2-Factor Authentication on Gmail
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Uncomment and fill below values

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-gmail-app-password
# EMAIL_FROM="Elective System <noreply@yourdomain.com>"

# Alternative Email Providers:
# 
# Outlook/Hotmail:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
#
# Yahoo Mail:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=465
# SMTP_SECURE=true
#
# SendGrid (Recommended for Production):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# ===== FRONTEND CONFIGURATION (.env.production) =====

# Backend API URL (Replace with your deployed backend URL)
VITE_API_BASE_URL=https://your-backend-app-name.onrender.com/api

# Example URLs for different platforms:
# Render: https://your-app-name.onrender.com/api
# Heroku: https://your-app-name.herokuapp.com/api
# Vercel: https://your-backend-domain.vercel.app/api
# Railway: https://your-app-name.railway.app/api
